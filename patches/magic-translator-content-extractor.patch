     /**
+     * Extract from a group field.
+     *
+     * A group is a single associative array of sub-field values (not a list of rows).
+     * Sub-field definitions live in $fieldConfig['fields'].
+     *
+     * @param  array<string, mixed>  $fieldConfig
+     * @param  array<string, mixed>  $value
+     * @return TranslationUnit[]
+     */
+    private function extractGroup(array $fieldConfig, array $value, string $path): array
+    {
+        $columnFields = $fieldConfig['fields'] ?? [];
+
+        if ($columnFields === []) {
+            return [];
+        }
+
+        return $this->extractWithPrefix($value, $columnFields, $path, insideContainer: true);
+    }
