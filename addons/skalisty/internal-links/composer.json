{
    "name": "skalisty/internal-links",
    "description": "Statamic addon for automatic keyword-based internal linking with per-locale keyword support",
    "version": "0.1.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Marcin Skibicki",
            "homepage": "https://skalisty.pl"
        }
    ],
    "keywords": [
        "statamic",
        "statamic-addon",
        "internal-links",
        "seo",
        "auto-link",
        "interlinking",
        "multilingual"
    ],
    "autoload": {
        "psr-4": {
            "Skalisty\\InternalLinks\\": "src"
        }
    },
    "require": {
        "php": "^8.2",
        "statamic/cms": "^6.0"
    },
    "extra": {
        "statamic": {
            "name": "Blog Internal Linking",
            "description": "Automatic keyword-based internal linking for blog content with per-locale keyword support"
        },
        "laravel": {
            "providers": [
                "Skalisty\\InternalLinks\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
